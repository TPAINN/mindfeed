# ── Required ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mindfeed
JWT_SECRET=change_me_to_a_long_random_string

# ── Admin ────────────────────────────────────────────────────────────────────────
# Bearer token for /api/admin/* routes — keep this long and random
ADMIN_PASSWORD=change_me_to_a_long_random_string

# ── AI Pipeline ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Content APIs (optional) ──────────────────────────────────────────────────────
# YouTube Data API v3 — https://console.developers.google.com
YOUTUBE_API_KEY=

# NASA APOD API — https://api.nasa.gov (leave empty to use DEMO_KEY)
NASA_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend origin (production only — set to your Render static site URL) ───────
# FRONTEND_URL=https://mindfeed.onrender.com
